{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/mfa-frontend/browser",
  "framework": "angular",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://auth-application.onrender.com/api/:path*"
    },
    {
      "source": "/oauth2/:path*",
      "destination": "https://auth-application.onrender.com/oauth2/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
